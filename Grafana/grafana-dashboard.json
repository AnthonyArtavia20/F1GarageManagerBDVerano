          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  c.Name AS Circuito,\n  COUNT(DISTINCT s.Simulation_id) AS Total_Simulaciones,\n  COUNT(sp.car_id) AS Total_Participantes,\n  AVG(sp.time_seconds) AS Tiempo_Promedio,\n  AVG(sp.v_recta) AS Velocidad_Recta_Promedio,\n  AVG(sp.v_curva) AS Velocidad_Curva_Promedio\nFROM SIMULATION s\nJOIN CIRCUIT c ON s.Circuit_id = c.Circuit_id\nLEFT JOIN SIMULATION_PARTICIPANT sp ON s.Simulation_id = sp.simulation_id\nGROUP BY c.Name\nORDER BY c.Name",
          "refId": "A",
